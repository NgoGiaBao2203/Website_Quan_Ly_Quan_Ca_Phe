@model DanhMucDoUong

@{
  ViewData["Title"] = "Chi tiết danh mục đồ uống";
  var isChuQuan = ViewBag.IsChuQuan as bool? ?? false;
}

<h1>Chi tiết danh mục đồ uống</h1>

<div>
  <hr />
  <dl class="row">
    <dt class="col-sm-4">Tên danh mục</dt>
    <dd class="col-sm-8">@Model.TenDanhMuc</dd>

    @if (isChuQuan)
    {
      <dt class="col-sm-4">Tạm xóa</dt>
      <dd class="col-sm-8">
        @if (Model.TrangThaiXoa == 1)
        {
          <i class="bi bi-x-circle-fill text-danger" title="Đã xóa"></i> <span>Đã xóa</span>
        }
        else
        {
          <i class="bi bi-check-circle-fill text-success" title="Đang hoạt động"></i> <span>Đang hoạt động</span>
        }
      </dd>
    }
  </dl>

  <h4 class="mt-4">Đồ uống thuộc danh mục</h4>
  @if (Model.DoUongs != null && Model.DoUongs.Any())
  {
    <table class="table table-bordered" style="max-width: 400px;">
      <thead>
        <tr>
          <th>Tên đồ uống</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var drink in Model.DoUongs)
        {
          <tr>
            <td>@drink.TenDoUong</td>
          </tr>
        }
      </tbody>
    </table>
  }
  else
  {
    <p class="text-muted">Không có đồ uống nào thuộc danh mục này.</p>
  }

  <div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.MaDanhMucDoUong" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
  </div>
</div>
