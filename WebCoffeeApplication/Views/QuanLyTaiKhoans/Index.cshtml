@model IEnumerable<WebCoffeeApplication.Models.TaiKhoan>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    var currentUserId = ViewBag.CurrentUserId as int?;
    var lastChuQuanId = ViewBag.LastChuQuanId as int?;
}

<h1>Quản lý tài khoản</h1>

<p>
    <!-- Nút điều hướng đến màn hình thêm tài khoản mới -->
    <a asp-action="Create" class="btn btn-primary">Thêm tài khoản mới</a>
</p>
<!-- Bảng danh sách tài khoản và các thao tác quản trị -->
<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>Họ và tên</th>
            <th>Vai trò</th>
            <th>Trạng thái</th>
            <th>Số điện thoại</th>
            <th>Tên đăng nhập</th>
            <th>Email</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.HoTen</td>
                <td>
                    @if (item.VaiTro == 1)
                    {
                        <span class="badge bg-danger">Chủ quán</span>
                    }
                    else
                    {
                        <span class="badge bg-info text-dark">Nhân viên</span>
                    }
                </td>
                <td class="text-center">
                    @if (item.TrangThaiXoa == 1)
                    {
                        <i class="bi bi-x-circle-fill text-danger" title="Đã xóa"></i>
                    }
                    else
                    {
                        <i class="bi bi-check-circle-fill text-success" title="Đang hoạt động"></i>
                    }
                </td>
                <td>@(string.IsNullOrWhiteSpace(item.SDT) ? "-" : item.SDT)</td>
                <td>@item.UserName</td>
                <td>@item.Email</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                    @if (item.TrangThaiXoa != 1
                       && !(currentUserId.HasValue && item.Id == currentUserId.Value)
                       && !(lastChuQuanId.HasValue && item.Id == lastChuQuanId.Value))
                    {
                        <button type="button" class="btn btn-sm btn-danger btn-delete" data-id="@item.Id" data-name="@item.HoTen">Xóa</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal xác nhận xóa tài khoản -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa tài khoản <strong id="deleteItemName"></strong> không?</p>
                <p class="text-danger"><small>Hành động này không thể hoàn tác.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
                // Gán URL động cho form xóa trong modal theo tài khoản được chọn.
                var baseDeleteUrl = '@Url.Action("Delete", "QuanLyTaiKhoans")';
                document.querySelectorAll('.btn-delete').forEach(function (btn) {
                        btn.addEventListener('click', function () {
                                var id = this.getAttribute('data-id');
                                var name = this.getAttribute('data-name');
                                document.getElementById('deleteItemName').textContent = name;
                                document.getElementById('deleteForm').action = baseDeleteUrl + '/' + id;
                                var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                                modal.show();
                        });
                });
        });
    </script>
}
