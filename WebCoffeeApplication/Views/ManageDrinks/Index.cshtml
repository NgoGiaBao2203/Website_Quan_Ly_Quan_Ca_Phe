@model WebCoffeeApplication.Helpers.PaginatedList<DoUong>

@{
    ViewData["Title"] = "Quản lý đồ uống";
    var isChuQuan = ViewBag.IsChuQuan as bool? ?? false;
}


<h1>Quản lý đồ uống</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm đồ uống mới</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="search" name="searchString" id="searchInput" value="@ViewData["SearchString"]" class="form-control" placeholder="Tìm kiếm theo tên đồ uống..." />
        <button type="submit" class="btn btn-outline-secondary">Tìm kiếm</button>
    </div>
</form>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>Hình ảnh</th>
            <th>Tên đồ uống</th>
            <th>Kích cỡ</th>
            <th>Giá bán</th>
            <th>Trạng thái</th>
            @if (isChuQuan)
            {
                <th>Tạm xóa</th>
            }
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.LinkHinhAnh))
                    {
                        <img src="@item.LinkHinhAnh" alt="@item.TenDoUong" style="width: 60px; height: 60px; object-fit: cover;" />
                    }
                </td>
                <td>@item.TenDoUong</td>
                <td>
                    @if (item.ChiTietDoUongs != null && item.ChiTietDoUongs.Any())
                    {
                        @foreach (var ct in item.ChiTietDoUongs)
                        {
                            <span class="badge bg-primary">@ct.KichCo</span>
                        
                            <br />
                        }
                    }
                </td>
                <td>
                    @if (item.ChiTietDoUongs != null && item.ChiTietDoUongs.Any())
                    {
                        @foreach (var ct in item.ChiTietDoUongs)
                        {
                            <span class="badge bg-info text-dark">@ct.GiaBan?.ToString("N0")đ</span>
                        
                            <br />
                        }
                    }
                </td>
                <td>
                    @if (item.TrangThai == 1)
                    {
                        <span class="badge bg-success">Đang bán</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ngừng bán</span>
                    }
                </td>
                @if (isChuQuan)
                {
                    <td class="text-center">
                        @if (item.TrangThaiXoa == 1)
                        {
                            <i class="bi bi-check-circle-fill text-success" title="Đã xóa"></i>
                        }
                        else
                        {
                            <i class="bi bi-x-circle-fill text-danger" title="Đang hoạt động"></i>
                        }
                    </td>
                }
                <td>
                    <a asp-action="Details" asp-route-id="@item.MaDoUong" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.MaDoUong" class="btn btn-sm btn-warning">Sửa</a>
                    @if (isChuQuan && item.TrangThaiXoa != 1)
                    {
                        <button type="button" class="btn btn-sm btn-danger btn-delete" data-id="@item.MaDoUong" data-name="@item.TenDoUong">Xóa</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">
        @if (Model.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" asp-route-searchString="@ViewData["SearchString"]">Trước</a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Trước</span>
            </li>
        }

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchString="@ViewData["SearchString"]">@i</a>
            </li>
        }

        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-searchString="@ViewData["SearchString"]">Sau</a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Sau</span>
            </li>
        }
    </ul>
</nav>

<!-- Modal xác nhận xóa -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa đồ uống <strong id="deleteItemName"></strong> không?</p>
                <p class="text-danger"><small>Hành động này không thể hoàn tác.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var baseIndexUrl = '@Url.Action("Index", "ManageDrinks")';
            window.addEventListener('pageshow', function (event) {
                var navigationEntries = performance.getEntriesByType('navigation');
                var navigationType = navigationEntries.length > 0 ? navigationEntries[0].type : '';
                if (event.persisted || navigationType === 'back_forward') {
                    window.location.href = baseIndexUrl;
                }
            });

            // Modal xác nhận xóa
            var baseDeleteUrl = '@Url.Action("Delete", "ManageDrinks")';
            document.querySelectorAll('.btn-delete').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = this.getAttribute('data-id');
                    var name = this.getAttribute('data-name');
                    document.getElementById('deleteItemName').textContent = name;
                    document.getElementById('deleteForm').action = baseDeleteUrl + '/' + id;
                    var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                    modal.show();
                });
            });

            // Tải lại danh sách đầy đủ khi xóa từ khóa tìm kiếm
            var searchInput = document.getElementById('searchInput');
            searchInput.addEventListener('search', function () {
                if (this.value === '') {
                    window.location.href = baseIndexUrl;
                }
            });
            searchInput.addEventListener('input', function () {
                if (this.value === '') {
                    window.location.href = baseIndexUrl;
                }
            });
        });
    </script>
}
