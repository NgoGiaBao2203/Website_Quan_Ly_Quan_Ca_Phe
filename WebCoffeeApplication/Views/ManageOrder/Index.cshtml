@model WebCoffeeApplication.Helpers.PaginatedList<HoaDon>

@{
    ViewData["Title"] = "Quản lý hóa đơn";
}

<h1>Quản lý đơn hàng</h1>

<!-- Bước 1: Nút điều hướng sang màn hình tạo đơn hàng mới. -->
<p>
    <a asp-action="Create" class="btn btn-primary">Tạo đơn hàng mới</a>
</p>

<!-- Bước 2: Form tìm kiếm theo mã hóa đơn hoặc số bàn. -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="search" name="searchString" id="searchInput" value="@ViewData["SearchString"]" class="form-control" placeholder="Tìm kiếm theo mã hóa đơn hoặc số bàn..." />
        <button type="submit" class="btn btn-outline-secondary">Tìm kiếm</button>
    </div>
</form>

<!-- Bước 3: Hiển thị danh sách hóa đơn theo dữ liệu đã lọc/phân trang. -->
<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>Mã hóa đơn</th>
            <th>Ngày tạo</th>
            <th>Số bàn</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaHoaDon</td>
                <td>@item.NgayTao?.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.SoBan</td>
                <td>@item.TongTien?.ToString("N0")đ</td>
                <td>
                    @* Bước 3.1: Hiển thị nhãn trạng thái theo enum trạng thái hóa đơn. *@
                    @switch (item.TrangThai)
                    {
                        case TrangThaiHoaDon.DangXuLy:
                            <span class="badge bg-warning text-dark">Đang xử lý</span>
                            break;
                        case TrangThaiHoaDon.DaLenMon:
                            <span class="badge bg-info text-dark">Đã lên món</span>
                            break;
                        case TrangThaiHoaDon.DaThanhToan:
                            <span class="badge bg-success">Đã thanh toán</span>
                            break;
                        case TrangThaiHoaDon.HuyDonHang:
                            <span class="badge bg-danger">Hủy đơn hàng</span>
                            break;
                        default:
                            <span class="badge bg-secondary">Không xác định</span>
                            break;
                    }
                </td>
                <td>
                    @* Bước 3.2: Các thao tác trên từng hóa đơn. *@
                    <a asp-action="Details" asp-route-id="@item.MaHoaDon" class="btn btn-sm btn-info">Chi tiết</a>
                    @* Bước 3.2.1: Chỉ cho phép sửa khi hóa đơn chưa ở trạng thái Đã thanh toán. *@
                    @if (item.TrangThai != TrangThaiHoaDon.DaThanhToan)
                    {
                        <a asp-action="Edit" asp-route-id="@item.MaHoaDon" class="btn btn-sm btn-warning">Sửa</a>
                    }
                    @* Bước 3.2.2: Chỉ hiển thị nút Thanh toán khi hóa đơn chưa thanh toán và chưa hủy. *@
                    @if (item.TrangThai != TrangThaiHoaDon.DaThanhToan && item.TrangThai != TrangThaiHoaDon.HuyDonHang)
                    {
                        <a asp-action="Payment" asp-route-id="@item.MaHoaDon" class="btn btn-sm btn-success">Thanh toán</a>
                    }
                    @* Bước 3.2.3: Chỉ cho xóa khi hóa đơn chưa thanh toán. *@
                    @if (item.TrangThai != TrangThaiHoaDon.DaThanhToan)
                    {
                        <button type="button" class="btn btn-sm btn-danger btn-delete" data-id="@item.MaHoaDon" data-name="Hóa đơn #@item.MaHoaDon">Xóa</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Bước 4: Điều hướng phân trang danh sách. -->
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">
        @if (Model.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" asp-route-searchString="@ViewData["SearchString"]">Trước</a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Trước</span>
            </li>
        }

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchString="@ViewData["SearchString"]">@i</a>
            </li>
        }

        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-searchString="@ViewData["SearchString"]">Sau</a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Sau</span>
            </li>
        }
    </ul>
</nav>

<!-- Bước 5: Modal xác nhận xóa hóa đơn. -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa <strong id="deleteItemName"></strong> không?</p>
                <p class="text-danger"><small>Hành động này không thể hoàn tác.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Bước 6: Đảm bảo quay về danh sách chuẩn khi điều hướng back/forward từ cache.
            var baseIndexUrl = '@Url.Action("Index", "ManageOrder")';
            window.addEventListener('pageshow', function (event) {
                var navigationEntries = performance.getEntriesByType('navigation');
                var navigationType = navigationEntries.length > 0 ? navigationEntries[0].type : '';
                if (event.persisted || navigationType === 'back_forward') {
                    window.location.href = baseIndexUrl;
                }
            });

            // Bước 7: Gắn dữ liệu vào modal và mở modal xác nhận xóa.
            var baseDeleteUrl = '@Url.Action("Delete", "ManageOrder")';
            document.querySelectorAll('.btn-delete').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = this.getAttribute('data-id');
                    var name = this.getAttribute('data-name');
                    document.getElementById('deleteItemName').textContent = name;
                    document.getElementById('deleteForm').action = baseDeleteUrl + '/' + id;
                    var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                    modal.show();
                });
            });

              // Bước 8: Khi xóa nội dung ô tìm kiếm thì tự tải lại danh sách đầy đủ.
            var searchInput = document.getElementById('searchInput');
            searchInput.addEventListener('search', function () {
                if (this.value === '') {
                    window.location.href = baseIndexUrl;
                }
            });
            searchInput.addEventListener('input', function () {
                if (this.value === '') {
                    window.location.href = baseIndexUrl;
                }
            });
        });
    </script>
}
