@model DoUong

@{
  ViewData["Title"] = "Chi tiết đồ uống";
  var isChuQuan = ViewBag.IsChuQuan as bool? ?? false;
}

<h1>Chi tiết đồ uống</h1>

<div>
  <hr />
  <div class="row">
    <div class="col-md-4">
      @if (!string.IsNullOrEmpty(Model.LinkHinhAnh))
      {
        <img src="@Model.LinkHinhAnh" alt="@Model.TenDoUong" class="img-fluid rounded" style="max-height: 300px; object-fit: contain;" />
      }
      else
      {
        <div class="text-muted text-center p-4 border rounded">Chưa có hình ảnh</div>
      }
    </div>
    <div class="col-md-8">
      <dl class="row">
        <dt class="col-sm-4">Tên đồ uống</dt>
        <dd class="col-sm-8">@Model.TenDoUong</dd>

        <dt class="col-sm-4">Danh mục</dt>
        <dd class="col-sm-8">@Model.DanhMucDoUong?.TenDanhMuc</dd>

        <dt class="col-sm-4">Trạng thái</dt>
        <dd class="col-sm-8">
          @if (Model.TrangThai == 1)
          {
            <span class="badge bg-success">Đang bán</span>
          }
          else
          {
            <span class="badge bg-secondary">Ngừng bán</span>
          }
        </dd>

        @if (isChuQuan)
        {
          <dt class="col-sm-4">Trạng thái xóa</dt>
          <dd class="col-sm-8">
            @if (Model.TrangThaiXoa == 1)
            {
              <i class="bi bi-x-circle-fill text-danger" title="Đã xóa"></i> <span>Đã xóa</span>
            }
            else
            {
              <i class="bi bi-check-circle-fill text-success" title="Đang hoạt động"></i> <span>Đang hoạt động</span>
            }
          </dd>
        }
      </dl>
    </div>
  </div>

  <h4 class="mt-4">Kích cỡ và giá bán</h4>
  @if (Model.ChiTietDoUongs != null && Model.ChiTietDoUongs.Any())
  {
    <table class="table table-bordered" style="max-width: 400px;">
      <thead>
        <tr>
          <th>Kích cỡ</th>
          <th>Giá bán</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var ct in Model.ChiTietDoUongs)
        {
          <tr>
            <td>@ct.KichCo</td>
            <td>@ct.GiaBan?.ToString("N0")đ</td>
          </tr>
        }
      </tbody>
    </table>
  }
  else
  {
    <p class="text-muted">Chưa có thông tin kích cỡ và giá bán.</p>
  }

  <div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.MaDoUong" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
  </div>
</div>
