@model WebCoffeeApplication.Helpers.PaginatedList<DanhMucDoUong>

@{
    ViewData["Title"] = "Quản lý danh mục đồ uống";
    var isChuQuan = ViewBag.IsChuQuan as bool? ?? false;
}

<h1>Quản lý danh mục đồ uống</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm danh mục mới</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Tên danh mục</th>
            @if (isChuQuan)
            {
                <th>Tạm xóa</th>
            }
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TenDanhMuc</td>
                @if (isChuQuan)
                {
                    <td class="text-center">
                        @if (item.TrangThaiXoa == 1)
                        {
                            <i class="bi bi-check-circle-fill text-success" title="Đã xóa"></i>
                        }
                        else
                        {
                            <i class="bi bi-x-circle-fill text-danger" title="Đang hoạt động"></i>
                        }
                    </td>
                }
                <td>
                    <a asp-action="Details" asp-route-id="@item.MaDanhMucDoUong" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.MaDanhMucDoUong" class="btn btn-sm btn-warning">Sửa</a>
                    @if (isChuQuan && item.TrangThaiXoa != 1)
                    {
                        <button type="button" class="btn btn-sm btn-danger btn-delete" data-id="@item.MaDanhMucDoUong" data-name="@item.TenDanhMuc" data-drink-count="@item.DoUongs.Count">Xóa</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">
        @if (Model.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)">Trước</a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Trước</span>
            </li>
        }

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
            </li>
        }

        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)">Sau</a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Sau</span>
            </li>
        }
    </ul>
</nav>

<!-- Modal xác nhận xóa -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa danh mục <strong id="deleteItemName"></strong> không?</p>
                <p id="deleteWarning" class="text-warning" style="display:none;">
                    <strong id="deleteDrinkCount"></strong> đồ uống liên quan sẽ bị xóa cùng với danh mục này.
                </p>
                <p class="text-danger"><small>Hành động này không thể hoàn tác.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var baseDeleteUrl = '@Url.Action("Delete", "ManageCategory")';
            document.querySelectorAll('.btn-delete').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = this.getAttribute('data-id');
                    var name = this.getAttribute('data-name');
                    var drinkCount = parseInt(this.getAttribute('data-drink-count')) || 0;
                    document.getElementById('deleteItemName').textContent = name;
                    document.getElementById('deleteForm').action = baseDeleteUrl + '/' + id;

                    var warningEl = document.getElementById('deleteWarning');
                    if (drinkCount > 0) {
                        document.getElementById('deleteDrinkCount').textContent = drinkCount;
                        warningEl.style.display = '';
                    } else {
                        warningEl.style.display = 'none';
                    }

                    var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                    modal.show();
                });
            });
        });
    </script>
}
